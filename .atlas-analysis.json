  "keyFeatures": [
    "Multi-currency digital wallets with real-time balance tracking",
    "Money transfers (send, request, exchange) between users",
    "Multiple deposit methods: bank, Stripe, PayPal, CoinPayments (crypto)",
    "Withdrawal/payout system with configurable payout settings",
    "Merchant payment processing with QR code and invoice generation",
    "Comprehensive admin panel for user, merchant, and financial management",
    "Role-based access control (RBAC) with granular permissions",
    "KYC verification (identity and address proof)",
    "Two-factor authentication (Google 2FA)",
    "Firebase push notifications and real-time updates via Pusher",
    "Dispute management system",
    "Support ticket system",
    "Addon/module system for extensibility",
    "Mobile API with Laravel Passport OAuth2 authentication",
    "Group-based bulk fund distribution",
    "Twilio SMS and email notification support"
  ],
