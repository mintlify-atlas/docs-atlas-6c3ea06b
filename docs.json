{
  "$schema": "https://mintlify.com/docs.json",
  "name": "DossPanels",
  "theme": "linden",
  "colors": {
    "primary": "#040404",
    "light": "#ef370f",
    "dark": "#f79d72"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/69d705f4-5e9b-4d51-bd5f-4788b2d5c4d2.svg",
    "dark": "https://media.brand.dev/69d705f4-5e9b-4d51-bd5f-4788b2d5c4d2.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/smonderoy/dosspanels"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/smonderoy/dosspanels"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "installation"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/user-roles",
              "concepts/wallets-currencies",
              "concepts/transaction-types"
            ]
          }
        ]
      },
      {
        "tab": "User Guide",
        "groups": [
          {
            "group": "Account Management",
            "pages": [
              "user-guide/registration",
              "user-guide/profile",
              "user-guide/kyc-verification",
              "user-guide/two-factor-auth"
            ]
          },
          {
            "group": "Payments & Transfers",
            "pages": [
              "user-guide/send-money",
              "user-guide/request-money",
              "user-guide/deposit",
              "user-guide/withdrawal",
              "user-guide/exchange-currency"
            ]
          },
          {
            "group": "Merchant Features",
            "pages": [
              "user-guide/merchant-payments",
              "user-guide/qr-codes",
              "user-guide/invoices"
            ]
          },
          {
            "group": "Other Features",
            "pages": [
              "user-guide/disputes",
              "user-guide/support-tickets",
              "user-guide/notifications"
            ]
          }
        ]
      },
      {
        "tab": "Admin Guide",
        "groups": [
          {
            "group": "Admin Panel",
            "pages": [
              "admin/dashboard",
              "admin/user-management",
              "admin/merchant-management"
            ]
          },
          {
            "group": "Finance & Settings",
            "pages": [
              "admin/currencies",
              "admin/fees-limits",
              "admin/payment-methods",
              "admin/crypto-providers"
            ]
          },
          {
            "group": "System",
            "pages": [
              "admin/roles-permissions",
              "admin/modules",
              "admin/email-sms-templates",
              "admin/activity-logs",
              "admin/backups"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Authentication",
            "pages": ["api/authentication", "api/registration"]
          },
          {
            "group": "Profile",
            "pages": ["api/profile"]
          },
          {
            "group": "Transactions",
            "pages": [
              "api/transactions",
              "api/send-money",
              "api/request-money",
              "api/deposit",
              "api/withdrawal",
              "api/exchange"
            ]
          },
          {
            "group": "Merchant",
            "pages": ["api/merchant-payments", "api/qr-codes"]
          }
        ]
      }
    ]
  }
}
